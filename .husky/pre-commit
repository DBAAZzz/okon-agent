#!/usr/bin/env sh
set -e

# Ensure common non-system Node locations are visible in git hook context.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Load nvm-managed Node if available (common on macOS/dev machines).
if ! command -v node >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
    nvm use --silent >/dev/null 2>&1 || true
  fi
fi

if ! command -v node >/dev/null 2>&1; then
  echo "husky(pre-commit): node not found in PATH, aborting."
  exit 127
fi

lint-staged
