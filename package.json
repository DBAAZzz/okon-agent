{
  "name": "okon-agent-monorepo",
  "version": "1.0.0",
  "description": "AI Agent with Fastify + tRPC + Next.js",
  "packageManager": "pnpm@8.7.5",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --stream dev",
    "dev:agent": "pnpm --filter @okon/agent dev",
    "dev:web": "pnpm --filter @okon/web dev",
    "build": "pnpm --filter @okon/shared --filter @okon/ui build && pnpm --filter @okon/agent... --filter @okon/web... build",
    "fmt": "pnpm --filter @okon/web fmt",
    "typecheck": "pnpm --recursive --stream typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,scss,md,mdx,html,yaml,yml}": [
      "./apps/web/node_modules/.bin/oxfmt"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
