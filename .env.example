# Environment Variables Setup
# Each app manages its own .env file in its directory

# Agent (apps/agent/.env)
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=your_openai_api_key
# Optional: OpenAI-compatible endpoint override (must target API base, usually ending in /v1)
OPENAI_BASE_URL=
# Legacy alias still supported by this project
# OPENAI_API_BASEURL=
TAVILY_API_KEY=your_tavily_api_key
BRAVE_API_KEY=your_brave_api_key
QDRANT_URL=http://localhost:6333
DATABASE_URL=postgresql://user:password@localhost:5432/okon-agent?schema=public

# Web (apps/web/.env.local) - currently no env vars needed
